{
  "name": "@bliss/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Bliss frontend bounded context (Vite + React 19 + TanStack Router + Panda CSS + Ark UI). See ADR-0002.",
  "scripts": {
    "dev": "pnpm panda:codegen && vite",
    "build": "pnpm panda:codegen && tsc -b && vite build",
    "build:preview": "pnpm panda:codegen && tsc -b && vite build --mode preview",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm panda:codegen && tsc -b",
    "lint": "eslint .",
    "panda:codegen": "panda codegen --silent",
    "prepare": "pnpm panda:codegen",
    "api:generate": "openapi-typescript ../grid/api/openapi.yaml -o src/infrastructure/api/grid/types.ts && openapi-typescript ../game/api/openapi.yaml -o src/infrastructure/api/game/types.ts",
    "api:check": "pnpm api:generate && git diff --exit-code -- src/infrastructure/api/grid/types.ts src/infrastructure/api/game/types.ts"
  },
  "dependencies": {
    "@ark-ui/react": "^4.9.0",
    "@fontsource-variable/nunito": "^5.2.7",
    "@tanstack/react-router": "^1.95.0",
    "msw": "^2.13.6",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@pandacss/dev": "^0.50.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fontaine": "^0.8.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "handlebars": "^4.7.9",
      "esbuild": "^0.25.0",
      "postcss": "^8.5.10"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}