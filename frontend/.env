# Default Grid API base URL — production. Per ADR-0007 §5 preview
# environments override this to point at the spec-driven MSW worker.
VITE_GRID_API_URL=https://api.wordsparrow.io

# Default Game API base URL — production. Both the REST surface
# (HttpLobbyClient) and the WebSocket surface (WebSocketGameClient)
# derive their URLs from this single value. The composition root
# in `main.tsx` reads it and threads adapters through router context.
VITE_GAME_API_BASE_URL=https://game.wordsparrow.io

# Multiplayer feature flag (ADR-0018 §10). Enabled in production now
# that the game-api Helm chart is live. `.env.development` and
# `.env.preview` keep this `false` until MSW handlers cover the lobby
# REST + WebSocket surfaces. Expires 2026-08-02 (90 days from
# first enablement).
VITE_FEATURE_MULTIPLAYER=true

# MSW disabled by default (production posture). `.env.preview`
# overrides this to `true` for Cloudflare Pages preview deploys, so
# the SPA replays the OpenAPI spec's `examples/` payloads instead of
# hitting the production API.
VITE_USE_MOCK_API=false

# Self-hosted Matomo (ADR-0025). When both vars are set, the cookieless
# tracker loads matomo.js and reports page views + custom events.
# `.env.development` and `.env.preview` blank these so local dev and
# preview builds never reach the prod analytics server.
VITE_MATOMO_URL=https://analytics.wordsparrow.io
VITE_MATOMO_SITE_ID=1
