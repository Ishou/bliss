{
  "alert": "BlissNatsConsumerLagWarning",
  "alertType": "METRIC_BASED_ALERT",
  "description": "NATS consumer max-pending exceeds 100 messages for 5m.",
  "ruleType": "promql_rule",
  "version": "v5",
  "schemaVersion": "v2alpha1",
  "condition": {
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "queries": [
        {
          "type": "promql",
          "spec": {
            "name": "A",
            "query": "max by (consumer_name, stream_name) (nats_consumer_num_pending)",
            "legend": "{{consumer_name}} / {{stream_name}}"
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "warning",
          "op": "above",
          "matchType": "at_least_once",
          "target": 100,
          "channels": []
        }
      ]
    }
  },
  "evaluation": {
    "kind": "rolling",
    "spec": {
      "evalWindow": "5m",
      "frequency": "1m"
    }
  },
  "labels": {
    "severity": "warning",
    "component": "nats"
  },
  "annotations": {
    "summary": "NATS consumer lag above warn threshold",
    "description": "Consumer {{$labels.consumer_name}} on stream {{$labels.stream_name}} has {{$value}} pending messages (> 100 for 5m)."
  },
  "notificationSettings": {
    "groupBy": [
      "consumer_name",
      "stream_name"
    ],
    "renotify": {
      "enabled": true,
      "interval": "4h",
      "alertStates": [
        "firing"
      ]
    }
  }
}
