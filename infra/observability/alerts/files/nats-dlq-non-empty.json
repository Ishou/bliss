{
  "alert": "BlissNatsDlqNonEmpty",
  "alertType": "METRIC_BASED_ALERT",
  "ruleType": "threshold_rule",
  "evalWindow": "1m0s",
  "frequency": "1m0s",
  "condition": {
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "promQueries": {
        "A": {
          "name": "A",
          "query": "nats_stream_messages{stream_name=\"WORDSPARROW_USER_EVENTS_DLQ\"}",
          "disabled": false
        }
      },
      "unit": ""
    },
    "op": "1",
    "target": 0,
    "matchType": "1",
    "selectedQueryName": "A"
  },
  "labels": {
    "severity": "warning",
    "component": "nats"
  },
  "annotations": {
    "summary": "Messages present in NATS DLQ stream",
    "description": "DLQ stream WORDSPARROW_USER_EVENTS_DLQ has {{$value}} messages — investigate consumer failures (max-delivery exhaustion). See infra/nats/README.md DLQ section."
  }
}
