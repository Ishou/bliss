{
  "name": "@bliss/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Bliss frontend bounded context (Vite + React 19 + TanStack Router + Panda CSS + Ark UI). See ADR-0002.",
  "scripts": {
    "dev": "pnpm panda:codegen && vite",
    "dev:preview": "pnpm panda:codegen && vite --mode preview",
    "build": "pnpm panda:codegen && tsc -b && vite build && pnpm seo:postbuild",
    "build:preview": "pnpm panda:codegen && tsc -b && vite build --mode preview && pnpm seo:postbuild",
    "seo:postbuild": "node --experimental-strip-types scripts/generate-sitemap.ts && node --experimental-strip-types scripts/prerender.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:post-build": "vitest run seo-prerender-output",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "a11y": "playwright test e2e/a11y.spec.ts",
    "typecheck": "pnpm panda:codegen && tsc -b",
    "lint": "eslint .",
    "panda:codegen": "panda codegen --silent",
    "prepare": "pnpm panda:codegen",
    "api:generate": "openapi-typescript ../grid/api/openapi.yaml -o src/infrastructure/api/grid/types.ts && openapi-typescript ../game/api/openapi.yaml -o src/infrastructure/api/game/types.ts",
    "api:check": "pnpm api:generate && git diff --exit-code -- src/infrastructure/api/grid/types.ts src/infrastructure/api/game/types.ts"
  },
  "dependencies": {
    "@ark-ui/react": "^4.9.0",
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource/lekton": "^5.2.8",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation": "^0.217.0",
    "@opentelemetry/instrumentation-document-load": "^0.62.0",
    "@opentelemetry/instrumentation-fetch": "^0.217.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-trace-web": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@tanstack/react-router": "^1.169.2",
    "msw": "^2.14.5",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.17.0",
    "@pandacss/dev": "^0.50.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fontaine": "^0.8.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.1"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "handlebars": "^4.7.9",
      "esbuild": "^0.25.0",
      "postcss": "^8.5.10",
      "fast-uri": "^3.1.2"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}