{
  "alert": "BlissNatsConsumerLagCritical",
  "alertType": "METRIC_BASED_ALERT",
  "description": "NATS consumer max-pending exceeds 1000 messages for 1m.",
  "ruleType": "promql_rule",
  "version": "v5",
  "schemaVersion": "v2alpha1",
  "condition": {
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "queries": [
        {
          "type": "promql",
          "spec": {
            "name": "A",
            "query": "max by (consumer_name, stream_name) (nats_consumer_num_pending)",
            "legend": "{{consumer_name}} / {{stream_name}}"
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "critical",
          "op": "above",
          "matchType": "at_least_once",
          "target": 1000,
          "channels": []
        }
      ]
    }
  },
  "evaluation": {
    "kind": "rolling",
    "spec": { "evalWindow": "1m", "frequency": "1m" }
  },
  "labels": { "severity": "critical", "component": "nats" },
  "annotations": {
    "summary": "NATS consumer lag above critical threshold",
    "description": "Consumer {{$labels.consumer_name}} on stream {{$labels.stream_name}} has {{$value}} pending messages (> 1000 for 1m)."
  }
}
