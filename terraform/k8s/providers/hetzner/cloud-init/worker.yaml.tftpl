#cloud-config
# k3s worker bootstrap. Joins the control plane via its PRIVATE IP
# (cp_ip) so the agent registers over the cluster's 10.0.0.0/16
# subnet — public 6443 traffic is allowed by the firewall too, but
# routing the join through the private network keeps the kubelet's
# advertised endpoint consistent with `node-ip` below.
#
# `node-ip` and `flannel-iface` pin k3s and flannel's vxlan to the
# Hetzner private interface (enp7s0 on Ubuntu 24.04). Without them
# k3s advertises the public IP and flannel's UDP/8472 vxlan traffic
# is dropped by the cluster firewall (intra-cluster TCP/UDP is scoped
# to 10.0.0.0/16). The values MUST be present at first boot — k3s
# only reads /etc/rancher/k3s/config.yaml at install time, so cloud-
# init's `write_files` (which runs before `runcmd`) is the only place
# this can land. Tweaking the file after install requires re-bootstrap.
#
# Pre-install loop avoids the "control-plane not ready" race that
# would otherwise show up as a flaky tofu apply.
#
# The install commands run from a write_files-materialized bash script
# rather than inline `runcmd` blocks because cloud-init executes inline
# `runcmd` entries via /bin/sh (dash on Ubuntu), which does not support
# `set -o pipefail`. Invoking a script by path lets cloud-init honor the
# `#!/bin/bash` shebang so `set -euo pipefail` works.
#
# Floating IP setup (ADR-0012, revised by ADR-0035). The worker is the
# assigned holder of the cluster's Hetzner floating IP (see
# hcloud_floating_ip_assignment in floating-ip.tf). Hetzner routes FIP
# traffic to this server at the network level, but the OS kernel
# rejects packets to addresses it does not know it owns — so we
# configure the FIP as a static address on eth0.
#
# The alias is declared in /etc/netplan/60-floating-ip.yaml (a netplan
# dropin merged with Hetzner's DHCP-driven 50-cloud-init.yaml). Going
# through netplan rather than a runtime `ip addr add` is the lesson
# from the 2026-05-10 incident: a runtime alias is silently wiped by
# any netplan/networkd reapply (DHCP renew, package upgrade, manual
# `netplan apply`), taking 80/443 down while the iptables 6443 DNAT
# rule keeps working — making the failure mode invisible to anything
# that probes the API server. Declarative netplan addresses survive
# every reapply because they ARE the desired state.
#
# Additionally, FIP:6443 traffic is DNAT'd to the CP's private IP so
# kubeconfigs hitting the FIP land on the k3s API server. The DNAT
# rule lives in floating-ip-config.service (runs at every boot,
# idempotent). The service is no longer responsible for the alias —
# only for iptables. See docs/incidents/2026-05-10-floating-ip-alias-wiped.md.

write_files:
  - path: /etc/rancher/k3s/config.yaml
    permissions: "0600"
    owner: root:root
    content: |
      node-ip: ${private_ip}
      flannel-iface: ${private_iface}
      # Append a random node-id suffix to the hostname so a
      # rebuilt worker (server_type bump, taint+apply, hardware swap)
      # joins the cluster under a fresh name. Without this the new
      # k3s-agent generates a fresh node password but the CP rejects
      # the join because /var/lib/rancher/k3s/server/cred/node-passwd
      # still has the old worker's entry under the same hostname —
      # "Node password rejected" loop. The id-suffix sidesteps the
      # whole collision instead of requiring CP-side cleanup at every
      # rebuild. Trade-off: node names go from deterministic
      # (wordsparrow-worker-0) to suffixed (wordsparrow-worker-0-a1b2c3d4),
      # so anything pinning workloads to a literal node name must use
      # a label selector instead.
      with-node-id: true
      node-label:
        - "bliss.io/role=${node_role}"
        - "bliss.io/cluster=${cluster_name}"
%{ if length(node_taints) > 0 ~}
      node-taint:
%{ for taint in node_taints ~}
        - "${taint}"
%{ endfor ~}
%{ endif ~}

  - path: /etc/sysctl.d/60-ip-forward.conf
    permissions: "0644"
    owner: root:root
    content: |
      # Required so iptables DNAT in floating-ip-config.service can
      # forward FIP:6443 traffic to the CP across the private network.
      net.ipv4.ip_forward=1

%{ if floating_ip != "" ~}
  - path: /etc/netplan/60-floating-ip.yaml
    # 0600 — netplan refuses to load world-readable config on Ubuntu 24.04.
    permissions: "0600"
    owner: root:root
    content: |
      # Hetzner ingress floating IP, declared as a static address on
      # eth0 so the kernel accepts FIP-destined packets locally
      # (otherwise it drops them as not-for-me and 80/443 go dark).
      #
      # This is a netplan dropin: it merges with the DHCP-driven
      # 50-cloud-init.yaml that Hetzner's images ship — DHCP keeps
      # leasing the public IP on eth0, this file just adds the FIP
      # alongside it. Higher-numbered file wins on conflicts; there is
      # no conflict here because we only set `addresses`.
      #
      # ADR-0035 — do NOT replace this with a runtime `ip addr add`.
      # See docs/incidents/2026-05-10-floating-ip-alias-wiped.md.
      network:
        version: 2
        ethernets:
          eth0:
            addresses:
              - ${floating_ip}/32

  - path: /usr/local/bin/floating-ip-config.sh
    permissions: "0755"
    owner: root:root
    content: |
      #!/bin/bash
      set -euo pipefail

      # The FIP alias on eth0 is owned by /etc/netplan/60-floating-ip.yaml
      # (ADR-0035). This script is responsible only for the iptables
      # NAT half — see the 2026-05-10 incident for why the alias was
      # moved out of here.

      # 1. Enable IPv4 forwarding (also persisted in /etc/sysctl.d/).
      sysctl -w net.ipv4.ip_forward=1 >/dev/null

      # 2. DNAT incoming TCP/6443 on the FIP to the CP's private IP.
      #    `-C` checks for existence first so we don't add duplicate
      #    rules across reboots.
      iptables -t nat -C PREROUTING -p tcp -d ${floating_ip} --dport 6443 \
          -j DNAT --to-destination ${cp_ip}:6443 2>/dev/null \
        || iptables -t nat -A PREROUTING -p tcp -d ${floating_ip} --dport 6443 \
             -j DNAT --to-destination ${cp_ip}:6443

      # 3. MASQUERADE on the egress side so the CP's reply transits
      #    back through this worker (otherwise the CP replies directly
      #    to the client from its own public IP, the connection breaks
      #    because the client expects replies from the FIP).
      iptables -t nat -C POSTROUTING -p tcp -d ${cp_ip} --dport 6443 \
          -j MASQUERADE 2>/dev/null \
        || iptables -t nat -A POSTROUTING -p tcp -d ${cp_ip} --dport 6443 \
             -j MASQUERADE

  - path: /etc/systemd/system/floating-ip-config.service
    permissions: "0644"
    owner: root:root
    content: |
      [Unit]
      Description=Configure Hetzner floating IP 6443 DNAT (alias is in netplan, ADR-0035)
      After=network-online.target
      Wants=network-online.target
      Before=k3s-agent.service

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/usr/local/bin/floating-ip-config.sh

      [Install]
      WantedBy=multi-user.target
%{ endif ~}

  - path: /usr/local/bin/install-k3s.sh
    permissions: "0755"
    owner: root:root
    content: |
      #!/bin/bash
      set -euo pipefail

      # Wait for Hetzner to attach the private network interface — hcloud_server_network
      # is applied after hcloud_server, so cloud-init can start before the NIC has its IP.
      # k3s reads node-ip from /etc/rancher/k3s/config.yaml at install time and refuses
      # to bind to an unassigned address; this loop closes the race.
      until ip -4 addr show "${private_iface}" 2>/dev/null | grep -q "inet "; do
        echo "Waiting for ${private_iface} to come up with an IPv4 address..."
        sleep 5
      done

      # Wait until the control-plane k3s API is listening on :6443.
      # We don't validate the body — k3s 1.30+ returns 401 (not "ok") for
      # unauthenticated /healthz requests; the agent install carries its
      # own auth via K3S_TOKEN. A successful TCP+TLS handshake is enough.
      until curl -sk --connect-timeout 5 -m 10 -o /dev/null \
          "https://${cp_ip}:6443/"; do
        sleep 5
      done

      export INSTALL_K3S_VERSION="${k3s_version}"
      export K3S_TOKEN="${k3s_token}"
      export K3S_URL="https://${cp_ip}:6443"
      curl -sfL https://get.k3s.io | sh -s - agent

runcmd:
  # Apply IP forwarding sysctl from /etc/sysctl.d/.
  - sysctl --system
%{ if floating_ip != "" ~}
  # Apply the netplan dropin so /etc/netplan/60-floating-ip.yaml takes
  # effect at first boot — installs the FIP alias on eth0 alongside
  # the DHCP-managed primary address. Idempotent; safe across reboots.
  # This MUST run before floating-ip-config.service so the kernel owns
  # the FIP locally before any service starts depending on it.
  - netplan apply
  # Enable + start the FIP DNAT unit so iptables rules for FIP:6443
  # are in place before k3s-agent comes up.
  - systemctl daemon-reload
  - systemctl enable --now floating-ip-config.service
%{ endif ~}
  - /usr/local/bin/install-k3s.sh
