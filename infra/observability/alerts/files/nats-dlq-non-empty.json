{
  "alert": "BlissNatsDlqNonEmpty",
  "alertType": "METRIC_BASED_ALERT",
  "description": "WORDSPARROW_USER_EVENTS_DLQ stream has at least one message for 1m.",
  "ruleType": "promql_rule",
  "version": "v5",
  "schemaVersion": "v2alpha1",
  "condition": {
    "compositeQuery": {
      "queryType": "promql",
      "panelType": "graph",
      "queries": [
        {
          "type": "promql",
          "spec": {
            "name": "A",
            "query": "nats_stream_messages{stream_name=\"WORDSPARROW_USER_EVENTS_DLQ\"}",
            "legend": "{{stream_name}}"
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [
        {
          "name": "warning",
          "op": "above",
          "matchType": "at_least_once",
          "target": 0,
          "channels": [
            "alerts@wordsparrow.io"
          ]
        }
      ]
    }
  },
  "evaluation": {
    "kind": "rolling",
    "spec": {
      "evalWindow": "1m",
      "frequency": "1m"
    }
  },
  "labels": {
    "severity": "warning",
    "component": "nats"
  },
  "annotations": {
    "summary": "Messages present in NATS DLQ stream",
    "description": "DLQ stream WORDSPARROW_USER_EVENTS_DLQ has {{$value}} messages for 1m - investigate consumer failures (max-delivery exhaustion). See infra/nats/README.md DLQ section."
  },
  "notificationSettings": {
    "groupBy": [
      "stream_name"
    ],
    "renotify": {
      "enabled": true,
      "interval": "2h",
      "alertStates": [
        "firing"
      ]
    }
  }
}
